{
  "name": "Social Media Performance Dark",
  "dataColors": [
    "#38BDF8",
    "#22C55E",
    "#F59E0B",
    "#F472B6",
    "#A78BFA",
    "#2DD4BF",
    "#FB7185",
    "#FACC15",
    "#60A5FA",
    "#34D399"
  ],
  "background": "#0F172A",
  "foreground": "#E5E7EB",
  "tableAccent": "#38BDF8",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#111827"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#334155"
              }
            },
            "radius": 4
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#CBD5E1"
              }
            },
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "fontSize": 24,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#94A3B8"
              }
            },
            "fontSize": 10
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "header": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "textSize": 9
          }
        ],
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#CBD5E1"
              }
            },
            "textSize": 10
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "outlineColor": {
              "solid": {
                "color": "#334155"
              }
            }
          }
        ]
      }
    }
  }
}
