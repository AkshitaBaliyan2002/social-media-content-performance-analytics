{
  "name": "Social Media Performance",
  "dataColors": [
    "#2F80ED",
    "#27AE60",
    "#F2994A",
    "#EB5757",
    "#9B51E0",
    "#00A3A3",
    "#F2C94C",
    "#5C6BC0",
    "#6FCF97",
    "#BB6BD9"
  ],
  "background": "#F7F8FA",
  "foreground": "#1F2933",
  "tableAccent": "#2F80ED",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#334155"
              }
            },
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E2E8F0"
              }
            },
            "radius": 4
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontSize": 22,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#64748B"
              }
            },
            "fontSize": 9
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "header": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#334155"
              }
            },
            "textSize": 9
          }
        ]
      }
    }
  }
}
